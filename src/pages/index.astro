---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Toolbar from "../components/Toolbar.astro";
import { ui } from "../i18n/ui";

const posts = await getCollection("posts");
---

<BaseLayout title="Quote to Cash">
    <div class="container">
        <main>
            <h1 id="pageTitle" data-key="title">{ui.es.title}</h1>
            <div class="feed">
                {
                    posts.map((post) => (
                        <a href={`/posts/${post.slug}`} class="post-card">
                            <span
                                class="tag"
                                style="color: var(--sf-blue); font-size: 0.7rem; font-weight: bold;"
                            >
                                {post.data.category}
                            </span>
                            <h2>{post.data.title}</h2>
                            <p style="color: #888; font-size: 0.8rem;">
                                {post.data.date.toLocaleDateString()}
                            </p>
                        </a>
                    ))
                }
            </div>
        </main>

        <aside>
            <Toolbar />
            <h3 data-key="recommended" style="font-size: 0.8rem; color: #888;">
                {ui.es.recommended}
            </h3>
            <p data-key="sidebarDesc" style="font-size: 0.9rem;">
                {ui.es.sidebarDesc}
            </p>
        </aside>
    </div>
</BaseLayout>
