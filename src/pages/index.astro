---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { ui } from "../i18n/ui";

const posts = await getCollection("posts");
---

<BaseLayout title="Quote to Cash | Salesforce Blog">
    <div class="content-grid">
        <section class="feed">
            {
                posts.length === 0 ? (
                    <p data-key="empty" class="empty-msg">
                        {ui.es.empty}
                    </p>
                ) : (
                    posts.map((post) => (
                        <a href={`/posts/${post.slug}`} class="post-card">
                            <span class="category-tag">
                                {post.data.category}
                            </span>
                            <h2>{post.data.title}</h2>
                            <div class="post-meta">
                                <span>
                                    {post.data.date.toLocaleDateString()}
                                </span>
                            </div>
                        </a>
                    ))
                )
            }
        </section>

        <aside class="sidebar">
            <div class="sidebar-section">
                <h3 data-key="recommended">{ui.es.recommended}</h3>
                <p data-key="sidebarDesc">{ui.es.sidebarDesc}</p>
            </div>

            <div class="sidebar-section">
                <div class="ad-placeholder">CPQ & Billing Resources</div>
            </div>
        </aside>
    </div>
</BaseLayout>

<style>
    .content-grid {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 60px;
        align-items: start;
    }

    .post-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 4px; /* Más cuadrado estilo Salesforce */
        padding: 30px;
        margin-bottom: 24px;
        text-decoration: none;
        color: inherit;
        display: block;
        transition:
            transform 0.2s ease,
            border-color 0.2s ease;
    }

    .post-card:hover {
        border-color: var(--sf-blue);
        transform: translateY(-2px);
    }

    .category-tag {
        color: var(--sf-blue);
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .post-card h2 {
        margin: 10px 0;
        font-size: 1.8rem;
        line-height: 1.2;
    }

    .post-meta {
        font-size: 0.85rem;
        color: #888;
    }

    .sidebar-section {
        margin-bottom: 40px;
    }

    .sidebar h3 {
        font-size: 0.8rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 15px;
        border-bottom: 2px solid var(--sf-blue);
        display: inline-block;
        padding-bottom: 4px;
    }

    .sidebar p {
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .ad-placeholder {
        background: var(--white);
        border: 1px dashed var(--border);
        padding: 40px 20px;
        text-align: center;
        font-size: 0.8rem;
        color: #888;
        border-radius: 4px;
    }

    @media (max-width: 900px) {
        .content-grid {
            grid-template-columns: 1fr;
        }
        .sidebar {
            order: -1;
        } /* Sidebar arriba en móvil para accesibilidad */
    }
</style>
