---
const { title = "Quote to Cash" } = Astro.props;
import { ui } from "../i18n/ui";
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>

        <link
            id="favicon"
            rel="icon"
            type="image/png"
            href="/mode/favicon-sun.png"
        />

        <script is:inline>
            const getStored = (key, fallback) =>
                localStorage.getItem(key) || fallback;
            const theme = getStored("theme", "light");
            const lang = getStored("lang", "es");

            document.documentElement.setAttribute("data-theme", theme);
            document.documentElement.setAttribute("data-lang", lang);

            const updateFavicon = (t) => {
                const f = document.getElementById("favicon");
                if (f)
                    f.href =
                        t === "dark"
                            ? "/mode/favicon-moon.png"
                            : "/mode/favicon-sun.png";
            };
            updateFavicon(theme);
        </script>
    </head>
    <body>
        <header class="main-header">
            <div class="container header-wrapper">
                <div class="header-left">
                    <a href="/" class="brand-logo-link">
                        <img
                            src="/assets/images/qtc-logo.png"
                            alt="QtC Logo"
                            class="nav-logo"
                        />
                    </a>
                </div>

                <div class="header-center">
                    <div class="search-bar">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><circle cx="11" cy="11" r="8"></circle><path
                                d="m21 21-4.3-4.3"></path></svg
                        >
                        <input
                            type="text"
                            placeholder="Buscar en Quote to Cash..."
                        />
                    </div>
                </div>

                <div class="header-right">
                    <div class="toolbar">
                        <button id="themeToggle" class="icon-btn">
                            <img
                                src="/mode/favicon-sun.png"
                                class="theme-icon sun-icon"
                                alt="Sol"
                            />
                            <img
                                src="/mode/favicon-moon.png"
                                class="theme-icon moon-icon"
                                alt="Luna"
                            />
                        </button>
                        <button id="langToggle" class="icon-btn">
                            <img
                                src="/flags/spain.png"
                                class="flag-icon flag-es"
                                alt="ES"
                            />
                            <img
                                src="/flags/uk.png"
                                class="flag-icon flag-en"
                                alt="EN"
                            />
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <div class="container main-content">
            <slot />
        </div>

        <style is:global>
            :root {
                --bg-color: #f5f5f7;
                --text-color: #181818;
                --sf-blue: #0176d3;
                --border: rgba(0, 0, 0, 0.1);
                --white: #ffffff;
            }

            [data-theme="dark"] {
                --bg-color: #1b2838;
                --text-color: #f5f5f7;
                --border: rgba(255, 255, 255, 0.1);
                --white: rgba(255, 255, 255, 0.05);
            }

            html,
            body {
                background-color: var(--bg-color);
                color: var(--text-color);
                margin: 0;
                font-family: -apple-system, system-ui, sans-serif;
                transition: background-color 0.3s ease;
                -webkit-font-smoothing: antialiased;
            }

            .container {
                max-width: 1100px;
                margin: 0 auto;
                padding: 0 20px;
            }

            .main-header {
                background-color: var(--white);
                border-bottom: 1px solid var(--border);
                /* REDUCIMOS PADDING AL MÍNIMO para compensar el logo grande */
                padding: 4px 0;
                position: sticky;
                top: 0;
                z-index: 1000;
                height: 64px; /* Altura fija para mantener control */
                display: flex;
                align-items: center;
            }

            .header-wrapper {
                display: flex;
                justify-content: space-between;
                align-items: center;
                width: 100%;
            }

            /* LOGO OPTIMIZADO */
            .nav-logo {
                height: 60px; /* Aumentamos el tamaño */
                width: auto;
                display: block;
                /* El margen negativo permite que el logo "ignore" un poco el padding del header */
                margin: -5px 0;
                transition: transform 0.2s ease;
            }

            .nav-logo:hover {
                transform: scale(1.02);
            }

            .header-center {
                flex: 1;
                max-width: 450px;
                margin: 0 30px;
            }

            .search-bar {
                position: relative;
                display: flex;
                align-items: center;
            }

            .search-bar svg {
                position: absolute;
                left: 12px;
                color: #888;
            }

            .search-bar input {
                width: 100%;
                padding: 8px 15px 8px 40px;
                border-radius: 8px;
                border: 1px solid var(--border);
                background-color: var(--bg-color);
                color: var(--text-color);
                font-size: 0.9rem;
                outline: none;
            }

            .toolbar {
                display: flex;
                gap: 20px;
            }
            .icon-btn {
                background: none;
                border: none;
                cursor: pointer;
                padding: 0;
                display: flex;
                align-items: center;
            }
            .theme-icon,
            .flag-icon {
                width: 24px;
                height: 24px;
                object-fit: contain;
            }

            .sun-icon,
            .moon-icon,
            .flag-es,
            .flag-en {
                display: none;
            }
            [data-theme="light"] .sun-icon {
                display: block;
            }
            [data-theme="dark"] .moon-icon {
                display: block;
            }
            [data-lang="es"] .flag-es {
                display: block;
            }
            [data-lang="en"] .flag-en {
                display: block;
            }

            .main-content {
                padding-top: 40px;
            }
        </style>
    </body>
</html>
